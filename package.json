{
  "name": "vibetip",
  "version": "0.1.0",
  "description": "Drop-in tip button for vibe-coded apps. One script tag, zero backend.",
  "license": "MIT",
  "author": "hyunjinee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyunjinee/vibetip.git"
  },
  "homepage": "https://github.com/hyunjinee/vibetip#readme",
  "bugs": "https://github.com/hyunjinee/vibetip/issues",
  "sideEffects": [
    "./dist/vibetip.iife.js"
  ],
  "type": "module",
  "main": "./dist/vibetip.js",
  "module": "./dist/vibetip.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vibetip.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && bun run build.ts && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "dev": "bun run build.ts --watch",
    "version-packages": "changeset version && bun run scripts/update-examples.mjs",
    "release": "bun run build && changeset publish"
  },
  "keywords": [
    "tip",
    "donation",
    "buy-me-a-coffee",
    "sponsor",
    "widget",
    "vibe-coding"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "human-id": "4.1.3"
  }
}
