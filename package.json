{
  "name": "vibetip",
  "version": "0.6.0",
  "description": "Drop-in KakaoPay tip button for vibe-coded apps. One script tag, zero backend.",
  "license": "MIT",
  "author": "hyunjinee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyunjinee/vibetip.git"
  },
  "homepage": "https://github.com/hyunjinee/vibetip#readme",
  "bugs": "https://github.com/hyunjinee/vibetip/issues",
  "sideEffects": [
    "./dist/vibetip.iife.js"
  ],
  "type": "module",
  "main": "./dist/vibetip.js",
  "module": "./dist/vibetip.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vibetip": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vibetip.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsc --noEmit && bun run build.ts && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun run build.ts --watch",
    "version-packages": "changeset version && bun run scripts/update-examples.mjs",
    "release": "bun run build && changeset publish"
  },
  "keywords": [
    "tip",
    "donation",
    "kakaopay",
    "qr-code",
    "widget",
    "vibe-coding"
  ],
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@happy-dom/global-registrator": "^20.10.6",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "bun-types": "^1.3.14",
    "lean-qr": "^2.7.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "human-id": "4.1.3"
  }
}
